{
  "name": "minimal-storefront",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev -p ${PORT:-3000} --turbo",
    "dev:test": "next dev -p 3002 --turbo",
    "dev:slow": "next dev -p ${PORT:-3000}",
    "dev:prod": "npm run build && next start -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "postinstall": "git -C .. config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@amboras-test-az/reviews": "^0.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@medusajs/js-sdk": "^2.13.4",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.17.19",
    "lucide-react": "^1.0.1",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
